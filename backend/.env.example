# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vercel AI Gateway API key (https://vercel.com/~/ai-gateway)
VERCEL_API_KEY=your_vercel_ai_gateway_key_here

# Default model to use (works with both providers)
DEFAULT_MODEL=google/gemini-2.0-flash-lite

# Image optimization / payload guards
IMAGE_MAX_BYTES=1500000
IMAGE_MAX_LONG_EDGE=1280
IMAGE_JPEG_QUALITY=75
IMAGE_WEBP_QUALITY=70
